# =========================================================
# WORKERS' COMPENSATION ANALYSIS
# =========================================================

# -------------------------
# 0. Packages and file paths
# -------------------------
library(readxl)
library(dplyr)
library(ggplot2)
library(MASS)

file_wc        <- "srcsc-2026-claims-workers-comp.xlsx"
file_macro     <- "srcsc-2026-interest-and-inflation.xlsx"
file_personnel <- "srcsc-2026-cosmic-quarry-personnel.xlsx"

# -------------------------
# 1. Validation rules
# -------------------------
valid_systems <- c("Epsilon", "Helionis Cluster", "Zeta")
valid_hours   <- c(20, 25, 30, 35, 40)
valid_index   <- c(1, 2, 3, 4, 5)
valid_claims  <- c(0, 1, 2)
valid_emp     <- c("Full time", "Contract")

# -------------------------
# 2. Load raw data
# -------------------------
freq_raw      <- read_excel(file_wc, sheet = "freq")
sev_raw       <- read_excel(file_wc, sheet = "sev")
macro_raw     <- read_excel(file_macro, skip = 2)
personnel_raw <- read_excel(file_personnel)

# -------------------------
# 3. Macro assumptions
# -------------------------
names(macro_raw) <- c("year", "inflation", "overnight_rate", "rf_1y", "rf_10y")

infl_ma <- mean(tail(macro_raw$inflation, 3), na.rm = TRUE)
rf1y_ma <- mean(tail(macro_raw$rf_1y, 3), na.rm = TRUE)
discount_rate <- rf1y_ma

# -------------------------
# 4. CQMC personnel data
# -------------------------
personnel <- personnel_raw %>%
  slice(-1, -2) %>%
  setNames(c("role", "num_employees", "full_time", "contract", "avg_salary", "avg_age")) %>%
  mutate(across(c(num_employees, full_time, contract, avg_salary, avg_age), as.numeric)) %>%
  filter(!is.na(num_employees), num_employees > 0)

total_workers <- sum(personnel$num_employees)

# -------------------------
# 5. Clean frequency data
# -------------------------
freq <- freq_raw %>%
  mutate(
    system           = sub("_.*", "", trimws(solar_system)),
    occupation_clean = sub("_.*", "", trimws(occupation)),
    station_clean    = sub("_.*", "", trimws(station_id)),
    employment_type  = trimws(employment_type),
    employment_type  = recode(
      employment_type,
      "Full-time" = "Full time",
      "Full time" = "Full time",
      "Contract"  = "Contract"
    )
  ) %>%
  filter(
    !is.na(system), system %in% valid_systems,
    !is.na(occupation_clean), occupation_clean != "",
    !is.na(station_clean), station_clean != "",
    !is.na(employment_type), employment_type %in% valid_emp,
    !is.na(exposure), exposure >= 0, exposure <= 1,
    !is.na(claim_count), claim_count %in% valid_claims,
    !is.na(experience_yrs), experience_yrs >= 0.2, experience_yrs <= 40,
    !is.na(accident_history_flag), accident_history_flag %in% c(0, 1),
    !is.na(psych_stress_index), psych_stress_index %in% valid_index,
    !is.na(hours_per_week), hours_per_week %in% valid_hours,
    !is.na(supervision_level), supervision_level >= 0, supervision_level <= 1,
    !is.na(gravity_level), gravity_level >= 0.75, gravity_level <= 1.50,
    !is.na(safety_training_index), safety_training_index %in% valid_index,
    !is.na(protective_gear_quality), protective_gear_quality %in% valid_index,
    !is.na(base_salary), base_salary >= 20000, base_salary <= 130000
  )

# -------------------------
# 6. Clean severity data
# -------------------------
sev <- sev_raw %>%
  mutate(
    system           = sub("_.*", "", trimws(solar_system)),
    occupation_clean = sub("_.*", "", trimws(occupation)),
    station_clean    = sub("_.*", "", trimws(station_id)),
    injury_type      = sub("_.*", "", trimws(injury_type)),
    injury_cause     = sub("_.*", "", trimws(injury_cause)),
    employment_type  = trimws(employment_type),
    employment_type  = recode(
      employment_type,
      "Full-time" = "Full time",
      "Full time" = "Full time",
      "Contract"  = "Contract"
    )
  ) %>%
  filter(
    !is.na(system), system %in% valid_systems,
    !is.na(occupation_clean), occupation_clean != "",
    !is.na(station_clean), station_clean != "",
    !is.na(employment_type), employment_type %in% valid_emp,
    !is.na(experience_yrs), experience_yrs >= 0.2, experience_yrs <= 40,
    !is.na(accident_history_flag), accident_history_flag %in% c(0, 1),
    !is.na(psych_stress_index), psych_stress_index %in% valid_index,
    !is.na(hours_per_week), hours_per_week %in% valid_hours,
    !is.na(supervision_level), supervision_level >= 0, supervision_level <= 1,
    !is.na(gravity_level), gravity_level >= 0.75, gravity_level <= 1.50,
    !is.na(safety_training_index), safety_training_index %in% valid_index,
    !is.na(protective_gear_quality), protective_gear_quality %in% valid_index,
    !is.na(base_salary), base_salary >= 20000, base_salary <= 130000,
    !is.na(claim_length), claim_length >= 3, claim_length <= 1000,
    !is.na(claim_amount), claim_amount > 0
  )

cat("Frequency rows kept:", nrow(freq), "\n")
cat("Severity rows kept:", nrow(sev), "\n")

# =========================================================
# 7. EDA
# =========================================================

occ_freq <- freq %>%
  group_by(occupation_clean) %>%
  summarise(
    total_claims   = sum(claim_count, na.rm = TRUE),
    total_exposure = sum(exposure, na.rm = TRUE),
    claim_rate     = total_claims / total_exposure,
    .groups = "drop"
  ) %>%
  arrange(desc(claim_rate))

occ_sev <- sev %>%
  group_by(occupation_clean) %>%
  summarise(
    claims       = n(),
    mean_claim   = mean(claim_amount, na.rm = TRUE),
    median_claim = median(claim_amount, na.rm = TRUE),
    p95_claim    = quantile(claim_amount, 0.95, na.rm = TRUE),
    max_claim    = max(claim_amount, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  arrange(desc(mean_claim))

freq_system <- freq %>%
  group_by(system) %>%
  summarise(
    total_claims   = sum(claim_count, na.rm = TRUE),
    total_exposure = sum(exposure, na.rm = TRUE),
    claim_rate     = total_claims / total_exposure,
    .groups = "drop"
  )

sev_system <- sev %>%
  group_by(system) %>%
  summarise(
    claims       = n(),
    mean_claim   = mean(claim_amount, na.rm = TRUE),
    median_claim = median(claim_amount, na.rm = TRUE),
    p95_claim    = quantile(claim_amount, 0.95, na.rm = TRUE),
    .groups = "drop"
  )

claim_length_summary <- sev %>%
  summarise(
    mean_days   = mean(claim_length, na.rm = TRUE),
    median_days = median(claim_length, na.rm = TRUE),
    p95_days    = quantile(claim_length, 0.95, na.rm = TRUE),
    max_days    = max(claim_length, na.rm = TRUE)
  )

injury_type_mix <- sev %>%
  filter(!is.na(injury_type), injury_type != "") %>%
  count(injury_type, sort = TRUE) %>%
  mutate(prop = n / sum(n))

injury_cause_mix <- sev %>%
  filter(!is.na(injury_cause), injury_cause != "") %>%
  count(injury_cause, sort = TRUE) %>%
  mutate(prop = n / sum(n))

# -------------------------
# EDA plots
# -------------------------
ggplot(occ_freq, aes(x = reorder(occupation_clean, claim_rate), y = claim_rate)) +
  geom_col() +
  coord_flip() +
  labs(title = "Claim Frequency by Occupation", x = "Occupation", y = "Claims per Exposure")

ggplot(sev, aes(x = occupation_clean, y = claim_amount)) +
  geom_boxplot() +
  coord_flip() +
  labs(title = "Claim Severity by Occupation", x = "Occupation", y = "Claim Amount")

ggplot(sev, aes(x = claim_length, y = claim_amount)) +
