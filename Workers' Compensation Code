ggplot(freq_system, aes(x = system, y = claim_rate)) +
  geom_col() +
  labs(title = "Claim Rate by Solar System", x = "Solar System", y = "Claims per Exposure")

# =========================================================
# 8. Modelling data
# =========================================================
freq_mod_data <- freq %>%
  mutate(
    system = factor(system),
    occupation_clean = factor(occupation_clean),
    employment_type = factor(employment_type),
    accident_history_flag = factor(accident_history_flag),
    psych_stress_index = factor(psych_stress_index),
    safety_training_index = factor(safety_training_index),
    protective_gear_quality = factor(protective_gear_quality)
  )

sev_mod_data <- sev %>%
  mutate(
    system = factor(system),
    occupation_clean = factor(occupation_clean),
    employment_type = factor(employment_type),
    accident_history_flag = factor(accident_history_flag),
    psych_stress_index = factor(psych_stress_index),
    safety_training_index = factor(safety_training_index),
    protective_gear_quality = factor(protective_gear_quality)
  )

# =========================================================
# 9. Frequency model
# =========================================================
pois_mod <- glm(
  claim_count ~ system + occupation_clean + employment_type + experience_yrs +
    accident_history_flag + psych_stress_index + hours_per_week +
    supervision_level + gravity_level + safety_training_index +
    protective_gear_quality + base_salary,
  family = poisson(link = "log"),
  offset = log(exposure),
  data = freq_mod_data
)

poisson_dispersion <- sum(residuals(pois_mod, type = "pearson")^2) / pois_mod$df.residual

if (poisson_dispersion > 1.2) {
  freq_model <- glm.nb(
    claim_count ~ system + occupation_clean + employment_type + experience_yrs +
      accident_history_flag + psych_stress_index + hours_per_week +
      supervision_level + gravity_level + safety_training_index +
      protective_gear_quality + base_salary + offset(log(exposure)),
    data = freq_mod_data
  )
  freq_model_type <- "Negative Binomial"
} else {
  freq_model <- pois_mod
  freq_model_type <- "Poisson"
}

cat("Selected frequency model:", freq_model_type, "\n")

# =========================================================
# 10. Severity model
# =========================================================
sev_model <- glm(
  log(claim_amount) ~ system + occupation_clean + employment_type + experience_yrs +
    accident_history_flag + psych_stress_index + hours_per_week +
    supervision_level + gravity_level + safety_training_index +
    protective_gear_quality + base_salary + claim_length,
  family = gaussian(),
  data = sev_mod_data
)

sev_sigma <- sigma(sev_model)

# =========================================================
# 11. Baseline pricing inputs
# =========================================================
freq_mod_data$pred_claims <- predict(freq_model, newdata = freq_mod_data, type = "response")

lambda_system <- freq_mod_data %>%
  group_by(system) %>%
  summarise(
    expected_claims   = sum(pred_claims),
    total_exposure    = sum(exposure),
    fitted_claim_rate = expected_claims / total_exposure,
    .groups = "drop"
  )

sev_mod_data$pred_log_claim <- predict(sev_model, newdata = sev_mod_data, type = "response")

sev_system_model <- sev_mod_data %>%
  group_by(system) %>%
  summarise(meanlog_hat = mean(pred_log_claim, na.rm = TRUE), .groups = "drop") %>%
  mutate(fitted_mean_severity = exp(meanlog_hat + 0.5 * sev_sigma^2))

worker_split <- lambda_system %>%
  mutate(
    exposure_share = total_exposure / sum(total_exposure),
    cqmc_workers   = total_workers * exposure_share
  ) %>%
  select(system, total_exposure, fitted_claim_rate, cqmc_workers)

pricing_inputs_base <- worker_split %>%
  left_join(sev_system_model, by = "system") %>%
  mutate(
    expected_claims         = fitted_claim_rate * cqmc_workers,
    expected_loss           = expected_claims * fitted_mean_severity,
    pure_premium_per_worker = expected_loss / cqmc_workers
  )

# =========================================================
# 12. Product design assumptions
# =========================================================
medical_share <- 0.35
wage_share    <- 0.45

waiting_period_days <- 21
deductible          <- 5000
policy_limit        <- 30000

rehab_long_claim_reduction <- 0.30
rehab_psych_reduction      <- 0.35

expense_loading <- 0.10
risk_margin     <- 0.15
profit_margin   <- 0.05

# =========================================================
# 13. Post-design claim adjustments
# =========================================================
sev_design <- sev %>%
  mutate(
    rehab_reduction = case_when(
      injury_type %in% c("Stress", "Psychological") ~ rehab_psych_reduction,
      claim_length > 30 ~ rehab_long_claim_reduction,
      TRUE ~ 0
    ),
    claim_length_post = pmax(1, claim_length * (1 - rehab_reduction)),
    claim_amount_trended = claim_amount * (1 + infl_ma)^(claim_length / 365),
    wage_benefit_factor = ifelse(
      claim_length_post > 0,
      pmax(claim_length_post - waiting_period_days, 0) / claim_length_post,
      0
    ),
    gross_claim_post = claim_amount_trended *
      (medical_share + wage_share * wage_benefit_factor) / (medical_share + wage_share),
    capped_claim_post = pmin(gross_claim_post, policy_limit),
    net_claim_post    = pmax(capped_claim_post - deductible, 0),
    payment_timing_years = claim_length_post / 365,
    pv_claim_post = net_claim_post / ((1 + discount_rate)^payment_timing_years)
  )

post_design_system <- sev_design %>%
  group_by(system) %>%
  summarise(
    payable_prop = mean(pv_claim_post > 0, na.rm = TRUE),
    meanlog_post = mean(log(pv_claim_post[pv_claim_post > 0]), na.rm = TRUE),
    sdlog_post   = sd(log(pv_claim_post[pv_claim_post > 0]), na.rm = TRUE),
    .groups = "drop"
  ) %>%
  mutate(
    sdlog_post = ifelse(is.na(sdlog_post) | sdlog_post <= 0, 0.01, sdlog_post),
    implied_mean_severity_post = exp(meanlog_post + 0.5 * sdlog_post^2)
  )

pricing_inputs_post <- worker_split %>%
  left_join(post_design_system, by = "system") %>%
  mutate(
    expected_claims         = fitted_claim_rate * cqmc_workers * payable_prop,
    expected_loss           = expected_claims * implied_mean_severity_post,
    pure_premium_per_worker = expected_loss / cqmc_workers,
    gross_premium_per_worker = pure_premium_per_worker * (1 + expense_loading + risk_margin + profit_margin)
  )

# =========================================================
# 14. Simulation functions
# =========================================================
simulate_portfolio <- function(pricing_tbl, n_sim = 10000, seed = 123) {
  set.seed(seed)

  totals <- replicate(n_sim, {
    total <- 0
    for (j in 1:nrow(pricing_tbl)) {
      n_claims <- rpois(1, pricing_tbl$expected_claims[j])
      if (n_claims > 0) {
        total <- total + sum(
          rlnorm(
            n_claims,
            meanlog = pricing_tbl$meanlog_post[j],
            sdlog   = pricing_tbl$sdlog_post[j]
          )
        )
      }
    }
    total
  })

  data.frame(total_loss = totals)
}

summarise_portfolio <- function(sim_df, label) {
  data.frame(
    portfolio = label,
    expected_loss = mean(sim_df$total_loss),
    variance = var(sim_df$total_loss),
    sd = sd(sim_df$total_loss),
    p95 = as.numeric(quantile(sim_df$total_loss, 0.95)),
    p99 = as.numeric(quantile(sim_df$total_loss, 0.99))
  )
}

stress_portfolio <- function(pricing_tbl, freq_mult, sev_mult, n_sim = 10000, seed = 456) {
  set.seed(seed)

  totals <- replicate(n_sim, {
    total <- 0
    for (j in 1:nrow(pricing_tbl)) {
      n_claims <- rpois(1, freq_mult * pricing_tbl$expected_claims[j])
      if (n_claims > 0) {
        total <- total + sum(
          sev_mult * rlnorm(
            n_claims,
            meanlog = pricing_tbl$meanlog_post[j],
            sdlog   = pricing_tbl$sdlog_post[j]
          )
        )
      }
    }
    total
  })

  data.frame(
    expected_loss = mean(totals),
    p95 = as.numeric(quantile(totals, 0.95)),
    p99 = as.numeric(quantile(totals, 0.99))
  )
}

# =========================================================
# 15. Baseline and post-design results
# =========================================================
sim_post <- simulate_portfolio(pricing_inputs_post, n_sim = 10000, seed = 123)
summary_post <- summarise_portfolio(sim_post, "Post-design")
print(summary_post)

# =========================================================
# 16. Stress testing
# =========================================================
stress_moderate <- stress_portfolio(pricing_inputs_post, 1.2, 1.25)
stress_severe   <- stress_portfolio(pricing_inputs_post, 1.5, 1.7)

stress_summary <- bind_rows(
  data.frame(
    scenario = "Base",
    expected_loss = summary_post$expected_loss,
    p95 = summary_post$p95,
    p99 = summary_post$p99
  ),
  data.frame(
    scenario = "Moderate stress",
    expected_loss = stress_moderate$expected_loss,
    p95 = stress_moderate$p95,
    p99 = stress_moderate$p99
  ),
  data.frame(
    scenario = "Severe stress",
    expected_loss = stress_severe$expected_loss,
    p95 = stress_severe$p95,
    p99 = stress_severe$p99
  )
)

print(stress_summary)

